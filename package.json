{
  "name": "crucible",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check:connection": "tsx scripts/check-connection.ts",
    "deploy:validation": "tsx scripts/deploy-validation.ts",
    "register:agent": "tsx scripts/register-agent.ts",
    "make:fixtures": "tsx scripts/make-fixtures.ts"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "solc": "0.8.26",
    "turbo": "^2.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
