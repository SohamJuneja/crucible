{
  "name": "crucible",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check:connection": "tsx scripts/check-connection.ts",
    "deploy:validation": "tsx scripts/deploy-validation.ts",
    "register:agent": "tsx scripts/register-agent.ts",
    "make:fixtures": "tsx scripts/make-fixtures.ts",
    "ingest:demo": "tsx scripts/ingest-demo.ts",
    "seed": "tsx scripts/seed-agents/run-all.ts",
    "leaderboard":    "tsx scripts/leaderboard.ts",
    "deploy:suite":   "tsx scripts/deploy-contracts-suite.ts",
    "deploy:vault":   "tsx scripts/deploy-vault.ts",
    "delegate:demo":  "tsx scripts/delegation-demo.ts",
    "deploy:dispute": "tsx scripts/deploy-dispute.ts",
    "dispute:demo":   "tsx scripts/dispute-demo.ts",
    "firewall:demo":  "tsx scripts/firewall-demo.ts",
    "sdk:example": "tsx scripts/sdk-example.ts",
    "seed:extra":       "tsx scripts/seed-extra.ts",
    "snapshot":         "tsx scripts/export-snapshot.ts",
    "verify:contracts": "tsx scripts/verify-contracts.ts",
    "web": "npm run dev -w @crucible/web"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "solc": "0.8.26",
    "turbo": "^2.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
