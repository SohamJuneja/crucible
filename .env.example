# Mantle Sepolia RPC endpoint (default is the public one — override with a private RPC for rate-limit-free access)
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz

# EOA private key used by Crucible to sign verdicts and call ERC-8004 registries (0x-prefixed hex, testnet only)
MANTLE_PRIVATE_KEY=0x...

# API key for Mantlescan contract verification and event indexing
MANTLESCAN_API_KEY=

# Pinata JWT for pinning claim payloads, verdict evidence, and agent registration files to IPFS
PINATA_JWT=

# DeepSeek API key used ONLY for human-readable verdict explanations (never for verdict logic)
DEEPSEEK_API_KEY=
